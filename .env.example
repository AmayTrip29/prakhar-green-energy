# ──────────────────────────────────────────────────────────────
# Prakhar Green Energy Solutions — Environment Variables
# Copy this file to .env.local for local development, and set the same
# keys in Vercel → Project Settings → Environment Variables for production.
# NEVER commit a real .env or .env.local file to git.
# ──────────────────────────────────────────────────────────────

# ── Database (Neon Postgres recommended) ───────────────────────
# Get these from your Neon project dashboard → Connection Details.
# DATABASE_URL: pooled connection (used at runtime by Prisma Client)
# DATABASE_URL_UNPOOLED: direct connection (used by `prisma migrate`)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true"
DATABASE_URL_UNPOOLED="postgresql://user:password@host/dbname?sslmode=require"

# ── NextAuth ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-byte-base64-string"
NEXTAUTH_URL="http://localhost:3000"

# ── Site URL (used in metadata, emails, JSON-LD) ────────────────
NEXT_PUBLIC_SITE_URL="https://www.prakhargreenenergy.com"

# ── Email (Resend) ───────────────────────────────────────────────
# Sign up at resend.com, verify your sending domain, then create an API key.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM_ADDRESS="Prakhar Green Energy <leads@prakhargreenenergy.com>"
LEAD_NOTIFICATION_EMAIL="info.prakhargreenenergy@gmail.com"

# ── WhatsApp (Meta Cloud API) — see docs/WHATSAPP_SETUP.md ──────
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_NOTIFY_NUMBER="917007629710"
WHATSAPP_TEMPLATE_NAME="new_lead_alert"

# ── Rate limiting (Upstash Redis) ────────────────────────────────
# Free tier at upstash.com is sufficient for this site's traffic.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Seed script (first deploy only — see docs/DEPLOYMENT.md) ────
SEED_ADMIN_EMAIL="admin@prakhargreenenergy.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
